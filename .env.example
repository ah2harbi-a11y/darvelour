# ---- Backend (serverless function on Vercel / local node server) ----

# libSQL / Turso database.
# Production: your Turso DB URL, e.g. libsql://darvelour-<org>.turso.io
# Local dev: leave unset to fall back to an on-disk SQLite file (file:server/darvelour.db)
TURSO_DATABASE_URL=
# Turso auth token (required whenever TURSO_DATABASE_URL is a remote libsql:// URL)
TURSO_AUTH_TOKEN=

# Secret used to sign customer JWTs. MUST be a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Secret used to sign admin JWTs. MUST be a long random string in production.
ADMIN_SECRET=change-me-to-a-different-long-random-string

# Vercel Blob read/write token for image uploads.
# On Vercel this is injected automatically once you connect a Blob store — do NOT set it there.
# Only needed locally if you want uploads to go to Blob instead of ./server/uploads.
BLOB_READ_WRITE_TOKEN=

# ---- Frontend ----
# Optional. The frontend calls the API at the relative path /api by default (same origin),
# which is correct for the Vercel deployment. Only set this to point at a different API origin.
# VITE_API_URL=
